@page
@model MvcApp.Pages.Students.DeleteModel
@{
    ViewData["Title"] = "Delete Student";
    Layout = "_Layout";
}

<h2>Delete Student</h2>

<h3>Are you sure you want to delete this student?</h3>
<div>
    <hr />
    <dl style="max-width: 600px;">
        <dt>Student ID</dt>
        <dd>@Model.Student.StudentId</dd>

        <dt>First Name</dt>
        <dd>@Model.Student.FirstName</dd>

        <dt>Last Name</dt>
        <dd>@Model.Student.LastName</dd>

        <dt>Age</dt>
        <dd>@Model.Student.Age</dd>

        <dt>Group</dt>
        <dd>@Model.Student.Group?.Name</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Student.StudentId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/Students" class="btn" style="background-color: #6c757d; color: white; margin-left: 10px;">Cancel</a>
    </form>
</div>