@page
@model MvcApp.Pages.Groups.EditModel
@{
    ViewData["Title"] = "Edit Group";
    Layout = "_Layout";
}

<h2>Edit Group - @Model.Group.GroupId</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="form-container">
    <form method="post">
        <input type="hidden" asp-for="Group.GroupId" />

        <div class="form-group">
            <label asp-for="Group.Name">Name</label>
            <input asp-for="Group.Name" class="form-control" required />
        </div>

        <div style="text-align: center;">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/Groups" class="btn" style="background-color: #6c757d; color: white; margin-left: 10px;">Cancel</a>
        </div>
    </form>
</div>