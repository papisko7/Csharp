<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoreEFTest</title>
    <style>
            body {
                font-family: Arial, sans-serif;
                margin: 0;
                padding: 0;
            }

            .navbar {
                background-color: #f8f9fa;
                padding: 15px 30px;
                border-bottom: 1px solid #dee2e6;
                margin-bottom: 20px;
            }

                .navbar a {
                    color: #007bff;
                    text-decoration: none;
                    margin-right: 20px;
                    font-size: 16px;
                }

                    .navbar a:hover {
                        text-decoration: underline;
                    }

                    .navbar a.brand {
                        font-weight: bold;
                        color: #212529;
                    }

            .container {
                padding: 0 30px;
            }

            table {
                border-collapse: collapse;
                width: 100%;
                margin: 20px 0;
            }

            th, td {
                border: 1px solid #dee2e6;
                padding: 12px;
                text-align: left;
            }

            th {
                background-color: #f8f9fa;
                font-weight: bold;
            }

            .form-container {
                max-width: 400px;
                margin: 30px auto;
                padding: 20px;
                border: 1px solid #dee2e6;
                border-radius: 5px;
            }

            .form-group {
                margin-bottom: 15px;
            }

                .form-group label {
                    display: block;
                    margin-bottom: 5px;
                    font-weight: bold;
                }

                .form-group input,
                .form-group select {
                    width: 100%;
                    padding: 8px;
                    border: 1px solid #ced4da;
                    border-radius: 4px;
                    box-sizing: border-box;
                }

            .btn {
                padding: 10px 20px;
                border: none;
                border-radius: 4px;
                cursor: pointer;
                text-decoration: none;
                display: inline-block;
            }

            .btn-primary {
                background-color: #007bff;
                color: white;
            }

                .btn-primary:hover {
                    background-color: #0056b3;
                }

            .btn-danger {
                background-color: #dc3545;
                color: white;
            }

                .btn-danger:hover {
                    background-color: #c82333;
                }

            .action-links a {
                margin-right: 10px;
                color: #007bff;
                text-decoration: none;
            }

                .action-links a:hover {
                    text-decoration: underline;
                }

            .alert {
                padding: 15px;
                margin-bottom: 20px;
                border: 1px solid transparent;
                border-radius: 4px;
            }

            .alert-danger {
                color: #721c24;
                background-color: #f8d7da;
                border-color: #f5c6cb;
            }

            .alert-success {
                color: #155724;
                background-color: #d4edda;
                border-color: #c3e6cb;
            }

            h2 {
                color: #212529;
                margin-bottom: 20px;
            }
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">CoreEFTest</a>
        <a href="/Students">Students</a>
        <a href="/Groups">Groups</a>
    </div>
    <div class="container">
        @RenderBody()
    </div>
</body>
</html>