@model MvcApp.Annotations.Student

<h2>Delete Student</h2>
<h4 class="text-danger">Are you sure you want to delete this student?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">First Name</dt>
        <dd class="col-sm-10">@Model.FirstName</dd>

        <dt class="col-sm-2">Last Name</dt>
        <dd class="col-sm-10">@Model.LastName</dd>

        <dt class="col-sm-2">Group</dt>
        <dd class="col-sm-10">@(Model.Group != null ? Model.Group.Name : "")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="StudentId" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button> |
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>